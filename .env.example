# ShipStation
SHIPSTATION_API_KEY=
SHIPSTATION_API_SECRET=

# Trello
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=
TRELLO_LIST_ID=

# Google Cloud (set automatically on Cloud Run via the service account)
# For local dev, point to a service account key file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
GOOGLE_CLOUD_PROJECT=your-project-id

# Optional: token for the /cron endpoint (Cloud Scheduler auth)
CRON_TOKEN=change-me-to-a-random-secret
